# chi_plot
# Purpose: Prepare a categorical variable (Size) from a numeric measurement (Sepal.Length)
# so that a chi-squared test can be applied to study the distribution of flower sizes.
# This chunk uses the built-in iris dataset and creates a simplified dataset that focuses
# only on the variables needed for categorical analysis and interpretation.
library(dplyr)  # Loads dplyr to enable pipe operations (%>%) and data transformation functions
head(iris)  # Displays the first few rows of the Iris dataset to understand its structure and variables
flowers <- iris %>%  # Begin with the iris dataset and pipe it into the following transformations
mutate(
Size = cut(
Sepal.Length,      # Converts Sepal.Length from a continuous numeric variable into categories
breaks = 3,         # Divides Sepal.Length into three equal-width groups
labels = c("Small", "Medium", "Large")  # Assigns descriptive labels to the three size groups
)
) %>%
select(Species, Size)  # Keeps only Species and Size to simplify the dataset for analysis
head(flowers)  # Displays the first few rows of the transformed flowers dataset to verify results
# Chi-squared goodness-of-fit test
# Purpose: Test whether the observed frequencies of flower Size categories differ from
# what would be expected under a uniform (equal) distribution assumption.
# This analysis helps determine whether certain size categories occur more or less
# frequently than expected by chance.
flowers %>%           # Start with the flowers dataset created earlier
select(Size) %>%    # Select only the Size variable, as the test focuses on size distribution
table() %>%         # Create a frequency table showing counts for each Size category
chisq.test()        # Perform the chi-squared goodness-of-fit test on the frequency table
# Linear Model
# Purpose: Examine the relationship between vehicle speed and stopping distance
# using a simple linear regression model.
# The model estimates how changes in speed are associated with changes in stopping distance
# and provides statistical measures to assess the strength and significance of this relationship.
library(dplyr)  # Loads dplyr (not required for lm(), but included as in the original code)
head(cars, 10)  # Displays the first 10 rows of the cars dataset to preview the variables used
cars %>%                               # Pipe the cars dataset into the modeling function
lm(dist ~ speed, data = .) %>%       # Fit a linear regression model: dist predicted by speed
summary()                            # Output model coefficients, p-values, and fit statistics
