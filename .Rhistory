# Load dplyr so we can use functions like select(), group_by(), summarise(), and arrange()
library(dplyr)
# Load the tidyverse collection (includes ggplot2, tidyr, readr, and also dplyr)
library(tidyverse)
# Show a list of datasets that R currently has access to (from loaded packages)
data()
# Open the msleep dataset in a spreadsheet-like viewer (works best in RStudio)
View(msleep)
# Show a compact overview: column names, types, and a few example values
glimpse(msleep)
# Minimum number of awake hours (ignoring missing values)
min_awake <- min(msleep$awake, na.rm = TRUE)
# Maximum number of awake hours (ignoring missing values)
max_awake <- max(msleep$awake, na.rm = TRUE)
# Range returns BOTH min and max together as a two-value output
range_awake <- range(msleep$awake, na.rm = TRUE)
# IQR measures spread of the middle 50% of the values (Q3 - Q1)
iqr_awake <- IQR(msleep$awake, na.rm = TRUE)
# Mean gives the average awake time
mean_awake <- mean(msleep$awake, na.rm = TRUE)
# Median gives the middle value when sorted
median_awake <- median(msleep$awake, na.rm = TRUE)
# Variance measures how spread out the awake values are around the mean
variance_awake <- var(msleep$awake, na.rm = TRUE)
# Display the calculated values so they show in the knitted output
min_awake
max_awake
range_awake
iqr_awake
mean_awake
median_awake
variance_awake
# Summary for the full dataset: gives stats for numeric columns and counts for factor/character columns
summary(msleep)
# Summary only for sleep_cycle (may contain missing values)
summary(msleep$sleep_cycle)
# Summary only for total hours of sleep
summary(msleep$sleep_total)
# Pick only sleep_total and brainwt columns, then show summary statistics
msleep %>%
select(sleep_total, brainwt) %>%
summary()
# Quick summary only for name, vore, and sleep_total (helps confirm columns exist and check missing values)
msleep %>%
select(name, vore, sleep_total) %>%
summary()
# Create a grouped summary table by vore (diet type)
msleep %>%
drop_na(vore) %>%                 # Remove rows where vore is missing, so grouping is clean
group_by(vore) %>%                # Group the dataset into categories based on vore
summarise(
Min_Sleep   = min(sleep_total, na.rm = TRUE),           # Smallest sleep_total in each vore group
Avg_Sleep   = mean(sleep_total, na.rm = TRUE),          # Average sleep_total in each vore group
Max_Sleep   = max(sleep_total, na.rm = TRUE),           # Largest sleep_total in each vore group
Sleep_Range = max(sleep_total, na.rm = TRUE) -
min(sleep_total, na.rm = TRUE)            # Range within each group
) %>%
arrange(Avg_Sleep)                # Sort from lowest average sleep to highest
# Load MASS package so we can access Cars93 dataset
library(MASS)
# Look at the structure and preview columns in Cars93
glimpse(Cars93)
# Count how many cars belong to each Origin category
table(Cars93$Origin)
# Create a two-way table showing counts for each combination of AirBags and Origin
table(Cars93$AirBags, Cars93$Origin)
# Add totals (margins) so we can see row sums and column sums clearly
addmargins(table(Cars93$AirBags, Cars93$Origin), 1)  # Adds totals across columns (row totals)
addmargins(table(Cars93$AirBags, Cars93$Origin), 2)  # Adds totals across rows (column totals)
addmargins(table(Cars93$AirBags, Cars93$Origin))     # Adds both row and column totals
# Calculate percentages within each Origin category (column-wise)
# The "2" means column proportions (each column adds up to 100%)
prop.table(table(Cars93$AirBags, Cars93$Origin), 2) * 100
# Round the percentage values to whole numbers for easy reading
round(prop.table(table(Cars93$AirBags, Cars93$Origin), 2) * 100)
Cars93 %>%
group_by(Origin, AirBags) %>%              # Make groups by Origin and AirBags together
summarise(number = n(), .groups = "drop") %>%  # Count how many records are in each group
pivot_wider(
names_from  = Origin,                    # Turn Origin values into new column names
values_from = number,                    # Put counts inside those new columns
values_fill = 0                          # If a combo is missing, fill with 0 instead of NA
)
# Show a list of datasets that R currently has access to (from loaded packages)
data()
# Open the msleep dataset in a spreadsheet-like viewer (works best in RStudio)
View(msleep)
# Load ggplot2 for plotting and dplyr for data filtering and transformation.
library(ggplot2)
library(dplyr)
# Store the built-in mpg dataset into a variable named 'data' for convenience.
data <- mpg
# View the internal structure of the dataset: column names and their data types.
str(data)
# View a quick statistical summary to understand ranges and distributions.
summary(data)
# Build a bar chart to count how many vehicles exist for each cylinder category.
ggplot(data, aes(x = factor(cyl))) +
geom_bar() +
labs(
title = "Number of Vehicles by Cylinder Count",
x = "Cylinders (Grouped)",
y = "Number of Vehicles"
)
# Create a scatter plot to compare city MPG and highway MPG for each vehicle.
ggplot(data, aes(x = cty, y = hwy)) +
geom_point() +
labs(
title = "Relationship Between City MPG and Highway MPG",
x = "City MPG",
y = "Highway MPG"
)
# Compare the distribution of city MPG across different vehicle classes using a boxplot.
ggplot(data, aes(x = class, y = cty)) +
geom_boxplot() +
labs(
title = "City MPG Distribution by Vehicle Class",
x = "Vehicle Class",
y = "City MPG"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Plot city vs highway MPG and use color to represent cylinder count.
ggplot(data, aes(x = cty, y = hwy, color = factor(cyl))) +
geom_point() +
labs(
title = "City vs Highway MPG Colored by Cylinder Count",
x = "City MPG",
y = "Highway MPG",
color = "Cylinders"
)
# Create separate panels for each year to compare the patterns across time.
ggplot(data, aes(x = cty, y = hwy, color = factor(cyl))) +
geom_point() +
facet_wrap(~year) +
labs(
title = "City vs Highway MPG by Year (Colored by Cylinders)",
x = "City MPG",
y = "Highway MPG",
color = "Cylinders"
)
# Display the column types and structure of the gapminder dataset.
str(gapminder)
# Show how engine size relates to highway fuel economy, with transmission type as color.
ggplot(data, aes(x = displ, y = hwy, color = trans)) +
geom_point() +
labs(
title = "Engine Displacement vs Highway MPG (Colored by Transmission)",
x = "Engine Displacement (Liters)",
y = "Highway MPG",
color = "Transmission"
)
# Load the gapminder dataset package.
library(gapminder)
# Preview the first few rows of the dataset.
head(gapminder)
# Display the column types and structure of the gapminder dataset.
str(gapminder)
# Print summary statistics for each column.
summary(gapminder)
# Choose five countries for comparison.
countries <- c("United States", "Italy", "India", "Brazil", "China")
# Filter the dataset to only include those countries.
filtered_data <- gapminder %>%
filter(country %in% countries)
# Plot GDP per capita vs life expectancy for the selected countries over time.
ggplot(filtered_data, aes(x = gdpPercap, y = lifeExp, color = country)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
labs(
title = "GDP per Capita vs Life Expectancy (Selected Countries)",
x = "GDP per Capita",
y = "Life Expectancy",
color = "Country"
)
# Load required libraries
library(ggplot2)      # ggplot2 is used for creating visualizations
library(dplyr)        # dplyr helps filter and manipulate data
library(gapminder)    # gapminder provides country-level data over time
# Create a vector that lists the five selected countries
selected_countries <- c("United States", "India", "China", "Brazil", "Germany")
# Filter the dataset so that it only includes the selected countries
filtered_data <- gapminder %>%
filter(country %in% selected_countries)
