# Copy the built-in dataset into a new variable so I can work with it safely
data1 <- anscombe
# Show the first 6 rows so I can see the structure and values quickly
head(data1)
# Summary gives min, max, median, mean, and quartiles for each column
summary(data1)
# Multiply every value in x3 by 5 (this stretches the x3 values to a wider scale)
data1$x3 <- data1$x3 * 5
# Add 2 to every value in y3 (this shifts the entire y3 set upward)
data1$y3 <- data1$y3 + 2
# Display the first few rows again to confirm the transformation happened
head(data1)
# Create a scatter plot of x1 vs y1
plot(
data1$x1,            # x-axis values
data1$y1,            # y-axis values
main = "Scatter Plot: x1 vs y1",  # title on top
xlab = "x1",         # label for x-axis
ylab = "y1"          # label for y-axis
)
# Create a scatter plot of x2 vs y2
plot(
data1$x2,
data1$y2,
main = "Scatter Plot: x2 vs y2",
xlab = "x2",
ylab = "y2"
)
# Create a scatter plot of the modified x3 vs modified y3
plot(
data1$x3,
data1$y3,
main = "Scatter Plot: x3 vs y3 (Modified)",
xlab = "x3 (multiplied by 5)",
ylab = "y3 (shifted up by 2)"
)
# Create a scatter plot of x4 vs y4
plot(
data1$x4,
data1$y4,
main = "Scatter Plot: x4 vs y4",
xlab = "x4",
ylab = "y4"
)
# Divide the plotting window into 2 rows and 2 columns
par(mfrow = c(2, 2))
# Plot 1
plot(data1$x1, data1$y1, main = "x1 vs y1", xlab="x1", ylab="y1")
# Plot 2
plot(data1$x2, data1$y2, main = "x2 vs y2", xlab="x2", ylab="y2")
# Plot 3 (modified)
plot(data1$x3, data1$y3, main = "x3 vs y3 (Modified)", xlab="x3", ylab="y3")
# Plot 4
plot(data1$x4, data1$y4, main = "x4 vs y4", xlab="x4", ylab="y4")
# Add one overall title across the full multi-plot view
mtext("Anscombe’s Quartet: All Four Scatter Plots", side = 3, line = -2, outer = FALSE)
# Set layout to 2 rows and 4 columns (8 plots total)
par(mfrow = c(2, 4))
# Boxplots for x variables
boxplot(data1$x1, main = "Boxplot: x1")
boxplot(data1$x2, main = "Boxplot: x2")
boxplot(data1$x3, main = "Boxplot: x3 (Modified)")
boxplot(data1$x4, main = "Boxplot: x4")
# Boxplots for y variables
boxplot(data1$y1, main = "Boxplot: y1")
boxplot(data1$y2, main = "Boxplot: y2")
boxplot(data1$y3, main = "Boxplot: y3 (Modified)")
boxplot(data1$y4, main = "Boxplot: y4")
# Use a 2x4 layout so all 8 histograms appear neatly
par(mfrow = c(2, 4))
# Histograms for x variables
hist(data1$x1, main = "Histogram: x1", xlab = "x1 values")
hist(data1$x2, main = "Histogram: x2", xlab = "x2 values")
hist(data1$x3, main = "Histogram: x3 (Modified)", xlab = "x3 values")
hist(data1$x4, main = "Histogram: x4", xlab = "x4 values")
# Histograms for y variables
hist(data1$y1, main = "Histogram: y1", xlab = "y1 values")
hist(data1$y2, main = "Histogram: y2", xlab = "y2 values")
hist(data1$y3, main = "Histogram: y3 (Modified)", xlab = "y3 values")
hist(data1$y4, main = "Histogram: y4", xlab = "y4 values")
# 2 rows x 4 columns for 8 barplots
par(mfrow = c(2, 4))
# Barplots for x variables (frequency counts)
barplot(table(data1$x1), main = "Barplot: x1", xlab = "x1", ylab = "Count")
barplot(table(data1$x2), main = "Barplot: x2", xlab = "x2", ylab = "Count")
barplot(table(data1$x3), main = "Barplot: x3 (Modified)", xlab = "x3", ylab = "Count")
barplot(table(data1$x4), main = "Barplot: x4", xlab = "x4", ylab = "Count")
# Barplots for y variables (may look messy because y has more unique values)
barplot(table(data1$y1), main = "Barplot: y1", xlab = "y1", ylab = "Count")
barplot(table(data1$y2), main = "Barplot: y2", xlab = "y2", ylab = "Count")
barplot(table(data1$y3), main = "Barplot: y3 (Modified)", xlab = "y3", ylab = "Count")
barplot(table(data1$y4), main = "Barplot: y4", xlab = "y4", ylab = "Count")
# Create a scatter plot of x2 vs y2
plot(
data1$x2,
data1$y2,
main = "Scatter Plot: x2 vs y2",
xlab = "x2",
ylab = "y2"
)
# Create a scatter plot of the modified x3 vs modified y3
plot(
data1$x3,
data1$y3,
main = "Scatter Plot: x3 vs y3 (Modified)",
xlab = "x3 (multiplied by 5)",
ylab = "y3 (shifted up by 2)"
)
