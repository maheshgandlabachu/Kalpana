ggplot(filtered_data, aes(x = gdpPercap, y = lifeExp, color = country)) +
geom_point() +  # Plot each country-year observation as a point
geom_smooth(method = "lm", se = FALSE, color = "black") +  # Add an overall linear regression trend line
labs(
title = "GDP per Capita vs Life Expectancy (Selected Countries)",
x = "GDP per Capita",
y = "Life Expectancy",
color = "Country"
) +
theme_minimal()  # Apply a clean theme for better readability
