"OD", "Prol")
# Make Class a factor because it is a categorical outcome
wineTib$Class <- as.factor(wineTib$Class)
# Check the updated data
wineTib
# Reshape from wide to long format (one row per Class/Variable/Value)
wineUntidy <- gather(wineTib, "Variable", "Value", -Class)
# Boxplots of each variable by class
ggplot(wineUntidy, aes(Class, Value)) +
facet_wrap(~ Variable, scales = "free_y") +
geom_boxplot() +
theme_bw()
# Create classification task with Class as target
wineTask <- makeClassifTask(data = wineTib, target = "Class")
# Define an LDA learner
lda <- makeLearner("classif.lda")
# Train the LDA model
ldaModel <- train(lda, wineTask)
# Get underlying LDA model
ldaModelData <- getLearnerModel(ldaModel)
# Predict discriminant scores (LD1, LD2, ...)
ldaPreds <- predict(ldaModelData)$x
# Look at first few rows
head(ldaPreds)
# Add LD1 and LD2 to the data and plot
wineTib %>%
mutate(LD1 = ldaPreds[, 1],
LD2 = ldaPreds[, 2]) %>%
ggplot(aes(LD1, LD2, col = Class)) +
geom_point() +
stat_ellipse() +
theme_bw()
# Define a QDA learner
qda <- makeLearner("classif.qda")
# Train the QDA model on the same task
qdaModel <- train(qda, wineTask)
# 10-fold CV repeated 50 times, with stratified folds
kFold <- makeResampleDesc(method = "RepCV", folds = 10, reps = 50,
stratify = TRUE)
# Cross-validate LDA
ldaCV <- resample(learner = lda, task = wineTask,
resampling = kFold,
measures = list(mmce, acc))
# Cross-validate QDA
qdaCV <- resample(learner = qda, task = wineTask,
resampling = kFold,
measures = list(mmce, acc))
# Aggregated performance
ldaCV$aggr
qdaCV$aggr
# Relative confusion matrices for LDA and QDA
ldaConf <- calculateConfusionMatrix(ldaCV$pred, relative = TRUE)
qdaConf <- calculateConfusionMatrix(qdaCV$pred, relative = TRUE)
ldaConf
qdaConf
# New wine sample ("poisoned" wine) with given chemical values
poisoned <- tibble(Alco = 13, Malic = 2, Ash = 2.2, Alk = 19, Mag = 100,
Phe = 2.3, Flav = 2.5, Non_flav = 0.35, Proan = 1.7,
Col = 4, Hue = 1.1, OD = 3, Prol = 750)
# Predict class with QDA
predict(qdaModel, newdata = poisoned)
# Data frame with only Class, LD1, LD2
wineDiscr <- wineTib %>%
mutate(LD1 = ldaPreds[, 1],
LD2 = ldaPreds[, 2]) %>%
select(Class, LD1, LD2)
# New classification task using only LD1 and LD2 as predictors
wineDiscrTask <- makeClassifTask(data = wineDiscr, target = "Class")
wineDiscrTask
# Parameter space: k from 1 to 10
knnParamSpace <- makeParamSet(
makeDiscreteParam("k", values = 1:10)
)
# Grid search tuning
gridSearch <- makeTuneControlGrid()
# Repeated 10-fold CV with 20 repetitions
cvForTuning <- makeResampleDesc("RepCV", folds = 10, reps = 20)
# Hyperparameter tuning for kNN
tunedK <- tuneParams("classif.knn",
task = wineDiscrTask,
resampling = cvForTuning,
par.set = knnParamSpace,
control = gridSearch)
tunedK$x
# Create kNN learner with best k
tunedKnn <- setHyperPars(makeLearner("classif.knn"),
par.vals = tunedK$x)
# Train final tuned model
tunedKnnModel <- train(tunedKnn, wineDiscrTask)
tunedKnnModel
